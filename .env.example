# ═══════════════════════════════════════════════
#  HomeShield Configuration (GPU Edition)
# ═══════════════════════════════════════════════

# Flask
SECRET_KEY=change-this-to-a-random-string
DEBUG=true
HOST=0.0.0.0
PORT=5000

# Detection
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.5
POSE_CONFIDENCE=0.5
POSE_TRACKING=0.5

# ── GPU / Inference ──────────────────────────────
# Device: "auto" | "cuda" | "cuda:0" | "mps" | "cpu"
GPU_DEVICE=auto

# FP16 half-precision on GPU (recommended: true)
USE_FP16=true

# Frames batched per GPU forward pass — set to number of active cameras
INFERENCE_BATCH_SIZE=4

# YOLO input size (multiple of 32; 640 = default YOLOv8 native)
YOLO_IMGSZ=640

# MediaPipe pose worker threads (parallel CPU pose estimation)
POSE_WORKERS=4

# Warmup inference passes on startup (eliminates first-frame latency)
WARMUP_FRAMES=3
# ─────────────────────────────────────────────────

# Alert thresholds
FALL_THRESHOLD=0.80
INACTIVITY_SECONDS=300
ALERT_COOLDOWN=60

# Frame processing
FRAME_WIDTH=640
FRAME_HEIGHT=480
PROCESS_FPS=15

# Twilio WhatsApp (get from https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_PHONE_NUMBERS=+60123456789,+60198765432
